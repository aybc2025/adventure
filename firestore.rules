rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGM() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/gm_users/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─── GM users (top-level, doc ID = uid) ───────────────────
    match /gm_users/{uid} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── Hero Templates ───────────────────────────────────────
    match /hero_templates/{id} {
      allow read: if isAuthenticated();
      allow write: if isGM();
    }

    // ─── Items catalog ────────────────────────────────────────
    match /items/{id} {
      allow read: if isAuthenticated();
      allow write: if isGM();
    }

    // ─── Adventures ───────────────────────────────────────────
    match /adventures/{advId} {
      allow read: if isGM() ||
                     (isAuthenticated() && resource.data.published == true);
      allow write: if isGM();

      match /rooms/{roomId} {
        allow read: if isGM() ||
                       (isAuthenticated() &&
                        get(/databases/$(database)/documents/adventures/$(advId))
                          .data.published == true);
        allow write: if isGM();
      }
    }

    // ─── Players ──────────────────────────────────────────────
    match /players/{uid} {
      allow read: if isOwner(uid) || isGM();
      allow create: if isOwner(uid) &&
                       request.resource.data.keys()
                         .hasOnly(['display_name','email','created_at','stats']);
      allow update: if isOwner(uid);
      allow delete: if isGM();

      // Personal heroes
      match /heroes/{heroId} {
        allow read: if isOwner(uid) || isGM();
        allow create: if isOwner(uid) &&
                         request.resource.data.keys().hasOnly([
                           'template_id','custom_name','class','hp_max',
                           'attack_dice','defense_dice','special_name',
                           'special_description','special_trigger','emoji',
                           'level','xp','xp_to_next_level','applied_upgrades',
                           'created_at','last_played'
                         ]);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid) || isGM();

        match /inventory/{itemId} {
          allow read, write: if isOwner(uid);
        }
      }

      // Sessions
      match /sessions/{sessionId} {
        allow read: if isOwner(uid) || isGM();
        allow create: if isOwner(uid) &&
                         request.resource.data.keys().hasOnly([
                           'adventure_id','hero_id','hero_hp',
                           'hero_inventory_snapshot','current_room_id',
                           'completed_rooms','monsters_defeated',
                           'started_at','updated_at','status'
                         ]);
        allow update: if isOwner(uid);
        allow delete: if isGM();
      }

      // History
      match /history/{historyId} {
        allow read: if isOwner(uid) || isGM();
        allow create: if isOwner(uid);
        allow update, delete: if isGM();
      }
    }
  }
}
